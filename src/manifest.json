{
  "manifest_version": "1.0",
  "id": "awair-element-local-api",
  "name": "Awair Element (Local API)",
  "version": "0.1.5",
  "description": "Integration for Awair Element devices over the local network",
  "maintainer": {
    "name": "PiPhi Network",
    "website": "https://piphi.io",
    "support_email": "support@piphi.io"
  },
  "platforms": [
    "linux",
    "windows",
    "macos"
  ],
  "runtime": {
    "linux": {
      "type": "container",
      "container": {
        "image": "piphinetwork/awair-element:0.1.5",
        "ports": [
          {
            "container": 3665,
            "host": 3665
          }
        ],
        "environment": {
          "LOG_LEVEL": "info"
        },
        "volumes": [
          {
            "host": "/data/awair",
            "container": "/app/data",
            "mode": "rw"
          }
        ],
        "restart_policy": {
          "name": "unless-stopped",
          "maximum_retry_count": 0
        }
      },
      "discovery": {
        "method": "direct"
      }
    },
    "windows": {
      "type": "proxy",
      "proxy": {
        "port": 3665
      },
      "discovery": {
        "method": "proxy"
      }
    },
    "macos": {
      "type": "proxy",
      "proxy": {
        "port": 3665
      },
      "discovery": {
        "method": "proxy"
      }
    }
  },
  "api": {
    "base_url": "http://127.0.0.1:3665",
    "endpoints": {
      "health": "/health",
      "discover": "/discover",
      "entities": "/entities",
      "state": "/state",
      "command": "/command",
      "config": "/config",
      "config_sync": "/configs/sync",
      "deconfigure": "/deconfigure",
      "ui_config": "/ui-config",
      "events": "/events"
    }
  },
  "config": {
    "source": "endpoint",
    "endpoint": "/ui-config",
    "required": true
  },
  "identity": {
    "fields": [
      "device_ip"
    ]
  },
  "capabilities": {
    "temperature": {
      "kind": "sensor",
      "unit": "\u00b0C",
      "dashboard": {
        "allowed_widgets": [
          "stat",
          "line_chart",
          "gauge"
        ],
        "default_widget": "stat"
      }
    },
    "dew_point": {
      "kind": "sensor",
      "unit": "\u00b0C",
      "dashboard": {
        "allowed_widgets": [
          "stat",
          "line_chart",
          "gauge"
        ],
        "default_widget": "stat"
      }
    },
    "humidity": {
      "kind": "sensor",
      "unit": "%",
      "dashboard": {
        "allowed_widgets": [
          "stat",
          "line_chart",
          "gauge"
        ],
        "default_widget": "gauge"
      }
    },
    "absolute_humidity": {
      "kind": "sensor",
      "unit": "g/m3",
      "dashboard": {
        "allowed_widgets": [
          "stat",
          "line_chart",
          "gauge"
        ],
        "default_widget": "stat"
      }
    },
    "co2": {
      "kind": "sensor",
      "unit": "ppm",
      "dashboard": {
        "allowed_widgets": [
          "stat",
          "line_chart",
          "gauge"
        ],
        "default_widget": "stat"
      }
    },
    "co2_est": {
      "kind": "sensor",
      "unit": "ppm",
      "dashboard": {
        "allowed_widgets": [
          "stat",
          "line_chart",
          "gauge"
        ],
        "default_widget": "stat"
      }
    },
    "co2_est_baseline": {
      "kind": "sensor",
      "unit": "ppm",
      "dashboard": {
        "allowed_widgets": [
          "stat",
          "line_chart",
          "gauge"
        ],
        "default_widget": "stat"
      }
    },
    "voc": {
      "kind": "sensor",
      "unit": "ppb",
      "dashboard": {
        "allowed_widgets": [
          "stat",
          "line_chart",
          "gauge"
        ],
        "default_widget": "stat"
      }
    },
    "voc_baseline": {
      "kind": "sensor",
      "unit": "ppb",
      "dashboard": {
        "allowed_widgets": [
          "stat",
          "line_chart",
          "gauge"
        ],
        "default_widget": "stat"
      }
    },
    "voc_h2_raw": {
      "kind": "sensor",
      "unit": "raw",
      "dashboard": {
        "allowed_widgets": [
          "stat",
          "line_chart"
        ],
        "default_widget": "stat"
      }
    },
    "voc_ethanol_raw": {
      "kind": "sensor",
      "unit": "raw",
      "dashboard": {
        "allowed_widgets": [
          "stat",
          "line_chart"
        ],
        "default_widget": "stat"
      }
    },
    "pm25": {
      "kind": "sensor",
      "unit": "ug/m3",
      "dashboard": {
        "allowed_widgets": [
          "stat",
          "line_chart",
          "gauge"
        ],
        "default_widget": "stat"
      }
    },
    "pm10_est": {
      "kind": "sensor",
      "unit": "ug/m3",
      "dashboard": {
        "allowed_widgets": [
          "stat",
          "line_chart",
          "gauge"
        ],
        "default_widget": "stat"
      }
    },
    "score": {
      "kind": "sensor",
      "unit": "%",
      "dashboard": {
        "allowed_widgets": [
          "stat",
          "line_chart",
          "gauge"
        ],
        "default_widget": "gauge"
      }
    },
    "refresh": {
      "kind": "action",
      "dashboard": {
        "allowed_widgets": [
          "button"
        ],
        "default_widget": "button"
      }
    }
  },
  "commands": {
    "refresh": {
      "description": "Force refresh device state",
      "timeout_ms": 5000
    }
  },
  "entities": [
    {
      "id": "temperature",
      "name": "Temperature",
      "capabilities": [
        "temperature"
      ]
    },
    {
      "id": "dew_point",
      "name": "Dew Point",
      "capabilities": [
        "dew_point"
      ]
    },
    {
      "id": "humidity",
      "name": "Humidity",
      "capabilities": [
        "humidity"
      ]
    },
    {
      "id": "absolute_humidity",
      "name": "Absolute Humidity",
      "capabilities": [
        "absolute_humidity"
      ]
    },
    {
      "id": "co2",
      "name": "CO\u2082",
      "capabilities": [
        "co2"
      ]
    },
    {
      "id": "co2_est",
      "name": "Estimated CO\u2082",
      "capabilities": [
        "co2_est"
      ]
    },
    {
      "id": "co2_est_baseline",
      "name": "CO\u2082 Baseline",
      "capabilities": [
        "co2_est_baseline"
      ]
    },
    {
      "id": "voc",
      "name": "VOC",
      "capabilities": [
        "voc"
      ]
    },
    {
      "id": "voc_baseline",
      "name": "VOC Baseline",
      "capabilities": [
        "voc_baseline"
      ]
    },
    {
      "id": "voc_h2_raw",
      "name": "VOC H\u2082 Raw",
      "capabilities": [
        "voc_h2_raw"
      ]
    },
    {
      "id": "voc_ethanol_raw",
      "name": "VOC Ethanol Raw",
      "capabilities": [
        "voc_ethanol_raw"
      ]
    },
    {
      "id": "pm25",
      "name": "PM2.5",
      "capabilities": [
        "pm25"
      ]
    },
    {
      "id": "pm10_est",
      "name": "Estimated PM10",
      "capabilities": [
        "pm10_est"
      ]
    },
    {
      "id": "score",
      "name": "Air Quality Score",
      "capabilities": [
        "score"
      ]
    },
    {
      "id": "refresh_action",
      "name": "Refresh",
      "capabilities": [
        "refresh"
      ]
    }
  ]
}
