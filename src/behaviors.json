      "actions": [
        {
          "id": "refresh_readings",
          "label": "Refresh readings",
          "description": "Request an immediate reading refresh",
          "capability": "device.refresh",
          "runtime": {
            "command": "refresh_readings"
          },
          "targeting": {
            "fanoutSafe": true,
            "scopes": [
              "config",
              "configs",
              "room",
              "rooms",
              "group",
              "groups",
              "selection",
              "tag",
              "tags",
              "capability",
              "all_matching"
            ],
            "supportsMultiTarget": true
          },
          "failure": {
            "strategy": "retry_then_continue",
            "retry": {
              "maxAttempts": 1,
              "delaySeconds": 2,
              "backoff": "fixed"
            },
            "timeoutSeconds": 30,
            "continueOnPartialFailure": true,
            "idempotent": true
          },
          "ui": {
            "group": "do_this"
          }
        },
        {
          "id": "notify",
          "label": "Send notification",
          "params": [
            {
              "name": "message",
              "label": "Notification message",
              "type": "text",
              "default": "Air quality threshold reached",
              "required": true
            },
            {
              "name": "channel",
              "label": "Delivery channel",
              "type": "enum",
              "options": [
                "in_app",
                "email",
                "sms"
              ],
              "default": "in_app",
              "required": true
            }
          ],
          "capability": "notification.send",
          "runtime": {
            "command": "notify"
          },
          "targeting": {
            "fanoutSafe": true,
