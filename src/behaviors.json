  "templates": [
    {
      "id": "awair_co2_alert",
      "label": "Tell me when CO2 is high",
      "description": "Checks the latest Awair reading and sends a notification when the room needs fresh air.",
      "category": "Air quality",
      "deviceKey": "awair_element",
      "config": {
        "automation_schema_version": "automation.behavior.v2",
        "triggers": [
          {
            "id": "state_changed",
            "label": "Awair reading changes",
            "type": "integration_event",
            "event": "device.state_changed",
            "capability": "telemetry.state",
            "enabled": true,
            "sourceRef": {
              "integrationId": "{{integrationId}}",
              "integrationKey": "{{integrationKey}}",
              "configId": "{{configId}}",
              "behaviorDeviceKey": "awair_element",
              "optionKey": "state_changed",
              "capability": "telemetry.state"
            }
          }
        ],
        "trigger": {
          "id": "state_changed",
          "label": "Awair reading changes",
          "type": "integration_event",
          "event": "device.state_changed",
          "capability": "telemetry.state",
          "enabled": true,
          "sourceRef": {
            "integrationId": "{{integrationId}}",
            "integrationKey": "{{integrationKey}}",
            "configId": "{{configId}}",
            "behaviorDeviceKey": "awair_element",
            "optionKey": "state_changed",
            "capability": "telemetry.state"
          }
        },
        "intent": "monitor_air_quality",
        "conditionTree": {
          "id": "co2_above_template",
          "label": "CO2 is above 1000 ppm",
          "field": "co2",
          "operator": ">",
          "value": 1000,
          "sourceRef": {
            "integrationId": "{{integrationId}}",
            "integrationKey": "{{integrationKey}}",
            "configId": "{{configId}}",
            "behaviorDeviceKey": "awair_element",
            "optionKey": "co2_above",
            "capability": "sensor.co2"
          }
        },
        "conditions": {
          "integrationCondition": {
            "id": "co2_above",
            "params": {
              "ppm": 1000
            }
          }
        },
        "actions": [
          {
            "id": "send_notification",
            "label": "Send notification",
            "action": "notify",
            "capability": "notification.send",
            "sourceRef": {
              "integrationId": "{{integrationId}}",
              "integrationKey": "{{integrationKey}}",
              "configId": "{{configId}}",
              "behaviorDeviceKey": "awair_element",
              "optionKey": "notify",
              "capability": "notification.send"
            },
            "target": {
              "mode": "selection",
              "configIds": [
                "{{configId}}"
              ]
            },
            "parameters": {
              "message": "CO2 is above 1000 ppm. It may be time to bring in fresh air.",
              "channel": "in_app"
            },
            "failure": {
              "strategy": "retry_then_continue",
              "retry": {
                "maxAttempts": 2,
                "delaySeconds": 2,
                "timeoutSeconds": 10,
                "backoff": "fixed"
              },
              "continueOnPartialFailure": true
            }
          }
        ],
        "safety": {
          "staleDataMode": "block",
          "maxAgeSeconds": 300,
          "requireFreshTrigger": true,
          "dryRunFirst": false
        },
        "failure": {
          "strategy": "follow_edges",
          "fallbackBehaviorId": "",
          "conditionTree": {
            "op": "and",
            "children": []
          }
        },
        "stop": {
          "never": true
        },
        "override": {
          "mode": "continue"
        }
      },
      "ui": {
        "accent": "air_quality",
        "icon": "wind"
      },
      "metadata": {
        "recommended": true,
        "difficulty": "easy"
      }
    },
